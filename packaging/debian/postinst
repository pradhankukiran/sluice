#!/bin/sh
# Post-install hook run by `dpkg` after sluiced + the service file
# land on disk. Reload systemd's view, but don't auto-start — the
# operator still has to `systemctl enable --now sluiced`.

set -e

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || true
fi

exit 0
